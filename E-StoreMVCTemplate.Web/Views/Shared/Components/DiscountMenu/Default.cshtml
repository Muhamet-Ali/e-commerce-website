@model List<GetDiscountForUserDto>

@{
    var count = Model?.Count ?? 0;

    // Her item için grid class'ı belirle
    string GetItemClass(int index, int total)
    {
        // Mobilde her zaman tek sütun
        // Masaüstünde:
        // 1 item -> tüm genişlik
        // 2 item -> yarı yarıya
        // 3 item -> üstte 2 yarı yarıya, alttaki tek başına full
        // 4+ item -> 2x2 grid (hepsi yarım)

        if (total == 1)
            return "md:col-span-2";

        if (total == 3 && index == 2)
            return "md:col-span-2";

        return "md:col-span-1";
    }
}

<section class="mb-8">
    <div class="px-8 md:px-16 mb-8">
        <h2 class="text-3xl font-bold tracking-tight text-slate-900">Seasonal Offers</h2>
        <p class="text-slate-500 font-medium">Curated selections for the discerning collector</p>
    </div>

    <div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
            @for (int i = 0; i < count; i++)
            {
                var discount = Model[i];
                var itemClass = GetItemClass(i, count);
                var isFullWidth = (count == 1) || (count == 3 && i == 2);

                <div class="@itemClass aspect-[4/5] sm:aspect-[16/10] @(isFullWidth ? "md:aspect-[21/9]" : "md:aspect-[1.2/1]") relative overflow-hidden group">
                    <img class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                         src="~/images/discounts/@discount.ImageUrl"
                         alt="@discount.Name" />

                    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/85 via-slate-900/30 to-transparent"></div>

                    <div class="absolute inset-0 flex flex-col justify-end p-6 md:p-10">
                        <h3 class="text-2xl md:text-4xl font-bold text-white mb-2 md:mb-3 tracking-tight">
                            @discount.Name
                        </h3>
                        <p class="text-white/85 text-sm md:text-base mb-4 md:mb-6 max-w-[400px]">
                            Up to %@discount.Rate off · Ends @discount.EndDate.ToString("MMM dd")
                        </p>
                        <a class="text-white font-semibold flex items-center gap-2 group/link w-fit"
                           asp-controller="Discount"
                           asp-action="GetDiscountProducts"
                           asp-route-id="@discount.Id">
                            Discover
                            <span class="material-symbols-outlined text-sm group-hover/link:translate-x-1 transition-transform">
                                arrow_forward
                            </span>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
