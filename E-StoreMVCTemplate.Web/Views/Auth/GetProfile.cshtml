
@{
    ViewData["Title"] = "GetProfile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen flex items-center justify-center px-4 py-12">

    <div class="w-full max-w-lg">

        <!-- Back Home -->
        <div class="mb-8">
            <a href="/" class="btn-ghost inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm text-white/50 hover:text-white/80 no-underline">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Back to Home
            </a>
        </div>

        <!-- Card -->
        <div class="glass rounded-3xl p-8 md:p-10">

            <!-- Alert (TempData) -->
            @if (TempData["Success"] != null)
            {
                <div class="alert-success rounded-xl px-4 py-3 mb-6 text-sm font-medium flex items-center gap-2">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert-error rounded-xl px-4 py-3 mb-6 text-sm font-medium flex items-center gap-2">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                    @TempData["Error"]
                </div>
            }

            <!-- Avatar + Name -->
            <div class="flex flex-col items-center mb-10">
                <div class="avatar-ring mb-4">
                    <div class="w-20 h-20 rounded-full bg-[#0a0a0f] flex items-center justify-center">
                        <span class="serif text-2xl text-white/80 select-none">
                            @(Model?.FullName?.Length > 0 ? Model.FullName[0].ToString().ToUpper() : "U")
                        </span>
                    </div>
                </div>
                <h1 class="serif text-2xl text-white/90 tracking-wide">@(Model?.FullName ?? "User")</h1>
                <p class="text-white/30 text-sm mt-1">Member Profile</p>
            </div>

            <!-- Profile Fields (read mode) -->
            <div id="view-mode" class="space-y-4">

                <div class="field-box rounded-xl px-5 py-4">
                    <p class="text-[10px] font-semibold uppercase tracking-widest text-white/30 mb-1">Full Name</p>
                    <p class="text-white/80 text-sm font-medium">@(Model?.FullName ?? "—")</p>
                </div>

                <div class="field-box rounded-xl px-5 py-4">
                    <p class="text-[10px] font-semibold uppercase tracking-widest text-white/30 mb-1">Email Address</p>
                    <p class="text-white/80 text-sm font-medium">@(Model?.Email ?? "—")</p>
                </div>

                <div class="field-box rounded-xl px-5 py-4">
                    <p class="text-[10px] font-semibold uppercase tracking-widest text-white/30 mb-1">Phone Number</p>
                    <p class="text-white/80 text-sm font-medium">@(Model?.PhoneNumber ?? "—")</p>
                </div>

                <div class="field-box rounded-xl px-5 py-4 opacity-40">
                    <p class="text-[10px] font-semibold uppercase tracking-widest text-white/30 mb-1">User ID</p>
                    <p class="text-white/50 text-xs font-mono">@(Model?.Id ?? "—")</p>
                </div>

                <!-- Update Button -->
                <button onclick="toggleEdit(true)" class="btn-primary w-full py-4 rounded-2xl text-white font-semibold text-sm tracking-wide mt-2">
                    Edit Profile
                </button>
            </div>

            <!-- Edit Form (hidden by default) -->
            <div id="edit-mode" class="hidden">
                <form asp-action="UpdateProfile" asp-controller="Profile" method="post" class="space-y-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model?.Id" />

                    <div class="field-box rounded-xl px-5 py-4">
                        <label class="text-[10px] font-semibold uppercase tracking-widest text-white/30 mb-2 block">Full Name</label>
                        <input type="text" name="FullName" value="@Model?.FullName" placeholder="Your full name" class="text-sm" />
                    </div>

                    <div class="field-box rounded-xl px-5 py-4">
                        <label class="text-[10px] font-semibold uppercase tracking-widest text-white/30 mb-2 block">Email Address</label>
                        <input type="email" name="Email" value="@Model?.Email" placeholder="your@email.com" class="text-sm" />
                    </div>

                    <div class="field-box rounded-xl px-5 py-4">
                        <label class="text-[10px] font-semibold uppercase tracking-widest text-white/30 mb-2 block">Phone Number</label>
                        <input type="tel" name="PhoneNumber" value="@Model?.PhoneNumber" placeholder="+1 000 000 0000" class="text-sm" />
                    </div>

                    <div class="flex gap-3 mt-2">
                        <button type="button" onclick="toggleEdit(false)" class="btn-ghost flex-1 py-4 rounded-2xl text-white/50 font-semibold text-sm">
                            Cancel
                        </button>
                        <button type="submit" class="btn-primary flex-1 py-4 rounded-2xl text-white font-semibold text-sm tracking-wide">
                            Save Changes
                        </button>
                    </div>
                </form>
            </div>

        </div>

        <!-- Footer note -->
        <p class="text-center text-white/15 text-xs mt-6">Changes are saved securely to your account.</p>
    </div>

    <script>
        function toggleEdit(on) {
            document.getElementById('view-mode').classList.toggle('hidden', on);
            document.getElementById('edit-mode').classList.toggle('hidden', !on);
        }
    </script>
</div>

















<style>
    * {
        font-family: 'DM Sans', sans-serif;
    }

    h1, h2, .serif {
        font-family: 'DM Serif Display', serif;
    }

    body {
        background: #0a0a0f;
        background-image: radial-gradient(ellipse 80% 50% at 20% 10%, rgba(99,102,241,0.12) 0%, transparent 60%), radial-gradient(ellipse 60% 40% at 80% 80%, rgba(168,85,247,0.08) 0%, transparent 55%);
    }

    .glass {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.07);
        backdrop-filter: blur(24px);
    }

    .field-box {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.07);
        transition: border-color 0.2s, background 0.2s;
    }

        .field-box:focus-within {
            border-color: rgba(99,102,241,0.6);
            background: rgba(99,102,241,0.05);
        }

    input {
        background: transparent;
        outline: none;
        color: #f1f0ff;
        width: 100%;
    }

        input::placeholder {
            color: rgba(255,255,255,0.2);
        }

        input:disabled {
            color: rgba(255,255,255,0.35);
            cursor: not-allowed;
        }

    .btn-primary {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
        box-shadow: 0 4px 24px rgba(99,102,241,0.25);
    }

        .btn-primary:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            box-shadow: 0 8px 32px rgba(99,102,241,0.35);
        }

        .btn-primary:active {
            transform: translateY(0);
        }

    .btn-ghost {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.09);
        transition: background 0.2s, transform 0.15s;
    }

        .btn-ghost:hover {
            background: rgba(255,255,255,0.09);
            transform: translateY(-1px);
        }

    .avatar-ring {
        background: linear-gradient(135deg, #6366f1, #a855f7, #ec4899);
        padding: 2px;
        border-radius: 50%;
    }

    .alert-success {
        background: rgba(34,197,94,0.1);
        border: 1px solid rgba(34,197,94,0.25);
        color: #86efac;
    }

    .alert-error {
        background: rgba(239,68,68,0.1);
        border: 1px solid rgba(239,68,68,0.25);
        color: #fca5a5;
    }
</style>