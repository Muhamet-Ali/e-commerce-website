@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model RegisterDto
<style>
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
</style>

<div class="bg-surface-container-low min-h-screen flex items-center justify-center p-6 antialiased">
    <div class="w-full max-w-5xl flex flex-col md:flex-row bg-surface-container-lowest rounded-xl shadow-xl overflow-hidden ring-1 ring-on-surface/5">


        <!-- Left Column: Aesthetic Imagery (Boutique Feel) -->
        <div class="hidden md:block md:w-5/12 relative">
            <div class="absolute inset-0 bg-primary/10 mix-blend-multiply z-10"></div>
            <img alt="minimalist aesthetic" class="absolute inset-0 h-full w-full object-cover" data-alt="Minimalist high-end fashion boutique interior with soft beige walls, clean lines, and architectural lighting in a serene atmosphere" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDDLRgaWx57InSdqwslYMvu9zxfi3XpJswrOie9KbEEVGuBMmRTZU3Poq3aCCf6jo4ydS9avtrF0E_b7agEq2RjLDNn0dEisTppE9tPLDYFgnFBXboMTdSe0TJBzarObV-6I35dA_eM0S8GG5g-1rAhCFyGegxBZgJz2UM2a3c51o248EKvm_rFn_ZWg6le78jYI-GRuBVoVSH40iQSitoPVMQKa6UyEwk1lip82s85nSWpTXfa2l4Tmbz0ZSEo-2JkRIh9IxUGnMyz" />
            <div class="absolute inset-0 flex flex-col justify-end p-10 z-20 bg-gradient-to-t from-on-surface/60 to-transparent">
                <h1 class="text-white text-3xl font-bold tracking-tight mb-2">ShopFlow</h1>
                <p class="text-white/80 font-medium text-sm leading-relaxed">Join our curated community of designers and trendsetters. Discover quality crafted for the modern lifestyle.</p>
            </div>
        </div>
        <!-- Right Column: Registration Form -->
        <div class="w-full md:w-7/12 p-8 md:p-12 lg:p-16 flex flex-col justify-center">
            <div class="mb-10">
                <h2 class="text-on-surface text-2xl font-extrabold tracking-tight mb-2">Create Account</h2>
                <p class="text-on-surface-variant text-sm">Welcome! Please enter your details to start your journey.</p>
            </div>
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="mb-5 flex items-start gap-3 bg-red-50 border border-red-200 text-red-800 rounded-xl px-4 py-3 text-sm">
                    <span class="material-symbols-outlined text-base mt-0.5">error</span>
                    <span>@TempData["ErrorMessage"]</span>
                </div>
            }

            <form asp-controller="Auth" asp-action="Register" method="post" class="space-y-5">
                <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm empty:hidden"></div>
                <!-- Username -->
                <div class="group">
                    <label class="block text-xs font-semibold uppercase tracking-wider text-on-surface-variant mb-1.5" asp-for="UserName"></label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[20px]">person</span>
                        <input asp-for="UserName"
                               class="w-full pl-10 pr-4 py-3 bg-surface-bright border border-outline-variant rounded-lg text-on-surface placeholder:text-outline/60 outline-none"
                               placeholder="johndoe" />
                    </div>
                    <span asp-validation-for="UserName" class="text-red-500 text-sm"></span>
                </div>
                <!-- Email -->
                <div class="group">
                    <label class="block text-xs font-semibold uppercase tracking-wider text-on-surface-variant mb-1.5" asp-for="Email"></label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[20px]">mail</span>
                        <input asp-for="Email"
                               class="w-full pl-10 pr-4 py-3 bg-surface-bright border border-outline-variant rounded-lg text-on-surface placeholder:text-outline/60 outline-none"
                               placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
                </div>

                <!-- Phone -->
                <div class="group">
                    <label class="block text-xs font-semibold uppercase tracking-wider text-on-surface-variant mb-1.5" asp-for="PhoneNumber"></label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[20px]">call</span>
                        <input asp-for="PhoneNumber"
                               class="w-full pl-10 pr-4 py-3 bg-surface-bright border border-outline-variant rounded-lg text-on-surface placeholder:text-outline/60 outline-none"
                               placeholder="+90 555 555 55 55" />
                    </div>
                    <span asp-validation-for="PhoneNumber" class="text-red-500 text-sm"></span>
                </div>
                <!-- Password -->
                <div class="group">
                    <label class="block text-xs font-semibold uppercase tracking-wider text-on-surface-variant mb-1.5" asp-for="Password"></label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[20px]">lock</span>
                        <input asp-for="Password"
                               type="password"
                               id="register-password"
                               class="w-full pl-10 pr-12 py-3 bg-surface-bright border border-outline-variant rounded-lg text-on-surface placeholder:text-outline/60 outline-none focus:border-primary focus:ring-4 focus:ring-primary-container/10 transition"
                               placeholder="••••••••" />
                        <button type="button" onclick="toggleRegisterPassword(this)"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-outline hover:text-primary transition">
                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                        </button>
                    </div>
                    <p class="text-[11px] text-on-surface-variant mt-1.5">Min. 8 characters · uppercase · lowercase · digit</p>
                    <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
                </div>
                <!-- Submit Button -->
                <button class="w-full bg-primary text-on-primary font-bold py-4 rounded-xl mt-4" type="submit">
                    Register
                </button>
            </form>
            <!-- Footer Link -->
            <div class="mt-8 text-center">
                <p class="text-on-surface-variant text-sm">
                    Already have an account?
                    <a class="text-primary font-bold hover:underline ml-1" asp-controller="Auth" asp-action="Login">Login</a>
                </p>
            </div>
        </div>


    </div>


</div>

<script>
    function toggleRegisterPassword(btn) {
        const input = document.getElementById('register-password');
        const icon = btn.querySelector('.material-symbols-outlined');
        if (input.type === 'password') {
            input.type = 'text';
            icon.textContent = 'visibility_off';
        } else {
            input.type = 'password';
            icon.textContent = 'visibility';
        }
    }
</script>
