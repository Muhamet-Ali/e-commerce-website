@{
    ViewData["Title"] = "GetSubCategoryWithProduct";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model GetSubCateogryByIdWithProductListDto

<main>
    <section class="pt-10 pb-20 max-w-[1920px] mx-auto">

        <div class="px-4 md:px-8 mb-10 md:mb-16">
            <nav class="text-[11px] tracking-[0.15em] text-slate-400 uppercase mb-4">
                <a asp-controller="Home" asp-action="Index" class="hover:text-slate-700 transition-colors">Home</a>
                <span class="mx-2">/</span>
                @if (Model.CategoryId > 0 && !string.IsNullOrEmpty(Model.CategoryName))
                {
                    <a asp-controller="Category" asp-action="GetCategoryWithProduct" asp-route-id="@Model.CategoryId"
                       class="hover:text-slate-700 transition-colors">@Model.CategoryName</a>
                    <span class="mx-2">/</span>
                }
                <span class="text-slate-700">@Model.Name</span>
            </nav>

            <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-slate-200 pb-6">
                <div>
                    <h1 class="text-3xl md:text-5xl font-light tracking-tight text-slate-900 uppercase">
                        @Model.Name
                    </h1>
                    <p class="text-slate-500 text-xs md:text-sm mt-2 font-light">
                        @Model.Products.Count items
                    </p>
                </div>
                <p class="text-slate-500 text-xs md:text-sm max-w-sm font-light leading-relaxed">
                    Each piece in our collection is hand-selected for its material integrity and timeless design.
                </p>
            </div>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-1 gap-y-10 md:gap-y-16">
            @foreach (var product in Model.Products)
            {
                var firstImage = product.Images?.FirstOrDefault();
                var imageUrl = firstImage != null ? $"/images/products/{firstImage.ImageUrl}" : "/images/placeholder.jpg";
                var hasDiscount = product.DiscountPrice.HasValue && product.DiscountPrice < product.Price;
                var discountPercent = hasDiscount
                ? (int)Math.Round((1 - (product.DiscountPrice!.Value / product.Price)) * 100)
                : 0;

                <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.Id"
                   class="group block">

                    <div class="relative overflow-hidden bg-slate-50 aspect-[3/4]">
                        <img class="w-full h-full object-cover transition-opacity duration-500 group-hover:opacity-90"
                             src="@imageUrl"
                             alt="@product.Name"
                             loading="lazy" />

                        <button type="button"
                                onclick="event.preventDefault(); event.stopPropagation();"
                                class="absolute bottom-3 right-3 w-8 h-8 md:w-9 md:h-9 flex items-center justify-center text-slate-700 hover:text-slate-900 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 md:w-[22px] md:h-[22px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                            </svg>
                        </button>
                    </div>

                    <div class="px-2 md:px-3 pt-3 md:pt-4">
                        <h3 class="text-xs md:text-sm text-slate-900 font-normal leading-snug line-clamp-2 min-h-[2.5rem]">
                            @product.Name
                        </h3>

                        <div class="mt-2 flex items-center gap-2 flex-wrap">
                            @if (hasDiscount)
                            {
                                <span class="text-xs md:text-sm text-slate-400 line-through">
                                    @product.Price.ToString("N2") TL
                                </span>
                                <span class="text-xs md:text-sm text-red-600 font-medium">
                                    @product.DiscountPrice!.Value.ToString("N2") TL
                                </span>
                                <span class="text-xs md:text-sm text-red-600 font-medium">
                                    −@discountPercent%
                                </span>
                            }
                            else
                            {
                                <span class="text-xs md:text-sm text-slate-900 font-normal">
                                    @product.Price.ToString("N2") TL
                                </span>
                            }
                        </div>
                    </div>
                </a>
            }
        </div>

    </section>
</main>
