@{
    ViewData["Title"] = "GetDiscountProducts";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@model GetDiscountByIdDto

<main>
    <section class="py-24 px-8 max-w-[1440px] mx-auto">

        <!-- Hero -->
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
            <div>
                <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded-full bg-error/10 text-error text-xs font-bold uppercase tracking-widest">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                        <path d="M6 1L7.5 4.5H11L8.5 6.8L9.5 10.5L6 8.5L2.5 10.5L3.5 6.8L1 4.5H4.5L6 1Z" fill="currentColor" />
                    </svg>
                    @Model.Rate.ToString("0")% Off
                </div>
                <h2 class="text-4xl md:text-5xl font-extrabold tracking-tighter text-on-surface">
                    @Model.Name
                </h2>
                <div class="h-1.5 w-24 bg-primary mt-4 rounded-full"></div>
            </div>

            <div class="flex flex-col gap-2 text-sm text-on-surface-variant font-medium">
                <div class="flex items-center gap-2">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="opacity-50">
                        <rect x="1" y="2" width="12" height="11" rx="2" stroke="currentColor" stroke-width="1.3" />
                        <path d="M1 6h12" stroke="currentColor" stroke-width="1.3" />
                        <path d="M4 1v2M10 1v2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" />
                    </svg>
                    @Model.StartDate.ToString("MMM dd") — @Model.EndDate.ToString("MMM dd, yyyy")
                </div>
                @if (Model.IsActive)
                {
                    <div class="inline-flex items-center gap-1.5 text-green-600 font-semibold">
                        <span class="w-1.5 h-1.5 rounded-full bg-green-500 inline-block"></span>
                        Active Campaign
                    </div>
                }
                else
                {
                    <div class="inline-flex items-center gap-1.5 text-on-surface-variant/50 font-semibold">
                        <span class="w-1.5 h-1.5 rounded-full bg-gray-300 inline-block"></span>
                        Ended
                    </div>
                }
            </div>
        </div>

        <!-- Grid -->
        @if (Model.Products == null || !Model.Products.Any())
        {
            <div class="flex flex-col items-center justify-center py-32 text-on-surface-variant/50">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none" class="mb-4 opacity-30">
                    <rect x="6" y="10" width="36" height="28" rx="4" stroke="currentColor" stroke-width="1.5" />
                    <path d="M6 18h36" stroke="currentColor" stroke-width="1.5" />
                    <path d="M16 28h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                </svg>
                <p class="font-semibold text-lg">No products in this campaign</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                @foreach (var product in Model.Products)
                {
                    var firstImage = product.Images?.FirstOrDefault();
                    var imageUrl = firstImage != null ? $"/images/products/{firstImage.ImageUrl}" : "/images/placeholder.jpg";
                    var hasDiscount = product.DiscountPrice.HasValue && product.DiscountPrice < product.Price;
                    var discountPercent = hasDiscount
                    ? (int)Math.Round((1 - (product.DiscountPrice!.Value / product.Price)) * 100)
                    : 0;

                    <div class="group relative flex flex-col bg-surface-container-lowest rounded-[32px] overflow-hidden transition-all duration-500 hover:shadow-[0_48px_64px_-12px_rgba(69,82,200,0.08)] hover:-translate-y-2">
                        <div class="relative aspect-[4/5] overflow-hidden">
                            <img class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                                 src="@imageUrl"
                                 alt="@product.Name" />

                            @if (hasDiscount)
                            {
                                <div class="absolute top-4 right-4 bg-error text-on-error px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">
                                    -@discountPercent%
                                </div>
                            }
                            else
                            {
                                <div class="absolute top-4 right-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest text-primary">
                                    New
                                </div>
                            }
                        </div>

                        <div class="p-8 space-y-4">
                            <div class="space-y-1">
                                <h3 class="text-xl font-bold tracking-tight text-on-surface">
                                    @product.Name
                                </h3>
                                <div class="flex items-center gap-3">
                                    <span class="text-lg font-extrabold text-primary">
                                        $@((hasDiscount ? product.DiscountPrice!.Value : product.Price).ToString("0.##"))
                                    </span>
                                    @if (hasDiscount)
                                    {
                                        <span class="text-sm text-outline-variant line-through">
                                            $@product.Price.ToString("0.##")
                                        </span>
                                    }
                                </div>
                            </div>
                            <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.Id"
                               class="block w-full py-3 rounded-xl border border-outline-variant/20 font-semibold text-sm text-center transition-all hover:bg-primary hover:text-on-primary hover:border-primary active:scale-95">
                                Quick View
                            </a>
                        </div>
                    </div>
                }
            </div>
        }

    </section>
</main>
