@using E_StoreMVCTemplate.Domain.Enums
@model PaymentCallbackDto

@{
    ViewData["Title"] = "Payment Result";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isSuccess = Model.Status == PaymentStatus.Success;
}

<div class="min-h-screen bg-background text-on-background">
    <div class="max-w-[720px] mx-auto px-4 md:px-8 py-16 md:py-24">
        <div class="bg-surface-container-lowest rounded-2xl border border-surface-container p-8 md:p-10 text-center">
            <div class="w-16 h-16 mx-auto rounded-full flex items-center justify-center mb-6 @(isSuccess ? "bg-emerald-50 text-emerald-700" : "bg-red-50 text-red-700")">
                <span class="material-symbols-outlined text-3xl">@(isSuccess ? "check_circle" : "error")</span>
            </div>

            <h1 class="text-2xl md:text-4xl font-extrabold tracking-tight text-on-surface">
                @(isSuccess ? "Payment Successful" : "Payment Failed")
            </h1>

            <p class="text-on-surface-variant text-sm mt-4">
                @(isSuccess ? "Your payment has been completed successfully." : Model.ErrorMessage ?? "Payment could not be completed.")
            </p>

            @if (!string.IsNullOrEmpty(Model.IyzicoPaymentId))
            {
                <p class="text-xs text-on-surface-variant mt-4">Payment Id: @Model.IyzicoPaymentId</p>
            }

            <div class="mt-8 flex justify-center gap-3">
                <a asp-controller="Home" asp-action="Index"
                   class="px-6 py-3 rounded-full bg-primary text-on-primary font-bold text-sm hover:opacity-90 transition-all">
                    Home
                </a>
                <a asp-controller="Cart" asp-action="ViewCart"
                   class="px-6 py-3 rounded-full bg-surface-container text-on-surface font-bold text-sm hover:bg-surface-container-high transition-all">
                    Cart
                </a>
            </div>
        </div>
    </div>
</div>
