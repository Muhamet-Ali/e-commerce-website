@using E_StoreMVCTemplate.Application.DTOs.Product
@model CreateDiscountDto

@{
    ViewData["Title"] = "Create Discount";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var products = (List<GetProductListDto>)ViewBag.Products;
}

<style>
    .product-picker {
        max-height: 460px;
        overflow-y: auto;
        border: 1px solid #dee2e6;
        border-radius: .5rem;
        background: #fff;
    }

    .product-row {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .55rem .85rem;
        border-bottom: 1px solid #f1f3f5;
        cursor: pointer;
        transition: background-color .12s;
    }

        .product-row:last-child {
            border-bottom: none;
        }

        .product-row:hover {
            background: #f8f9fa;
        }

        .product-row.is-checked {
            background: #eef0ff;
        }

    .product-thumb {
        width: 48px;
        height: 48px;
        flex-shrink: 0;
        border-radius: .35rem;
        object-fit: cover;
        background: #f1f3f5;
    }

    .product-thumb-placeholder {
        width: 48px;
        height: 48px;
        flex-shrink: 0;
        border-radius: .35rem;
        background: #f1f3f5;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #adb5bd;
        font-size: .75rem;
    }

    .product-meta {
        flex: 1;
        min-width: 0;
    }

    .product-name {
        font-weight: 600;
        font-size: .9rem;
        color: #212529;
        margin: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .product-sub {
        font-size: .75rem;
        color: #6c757d;
        margin-top: 2px;
    }

    .product-row .form-check-input {
        margin: 0;
        flex-shrink: 0;
        width: 18px;
        height: 18px;
        cursor: pointer;
    }

    .picker-toolbar {
        display: flex;
        gap: .5rem;
        align-items: center;
        margin-bottom: .5rem;
    }

    .picker-summary {
        font-size: .8rem;
        color: #495057;
    }
</style>

<div class="container-fluid px-4 mt-4">

    <h2>Create Discount</h2>

    <form asp-area="Admin"
          asp-controller="Discount"
          asp-action="Create"
          method="post"
          enctype="multipart/form-data">

        <div class="card p-4">

            <!-- NAME -->
            <div class="mb-3">
                <label>Name</label>
                <input asp-for="Name" class="form-control" required />
            </div>

            <!-- RATE -->
            <div class="mb-3">
                <label>Rate</label>
                <div class="input-group">
                    <input asp-for="Rate" type="number" class="form-control"
                           min="1" max="100" step="1" required
                           oninvalid="this.setCustomValidity('Rate must be between 1 and 100.')"
                           oninput="this.setCustomValidity('')" />
                    <span class="input-group-text">%</span>
                </div>
                <small class="text-muted">Discount rate must be at least 1%.</small>
            </div>

            <!-- DATE -->
            <div class="mb-3">
                <label>Start Date</label>
                <input asp-for="StartDate" type="date" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>End Date</label>
                <input asp-for="EndDate" type="date" class="form-control" required />
            </div>

            <!-- FILE -->
            <div class="mb-3">
                <label>Image</label>
                <input asp-for="File" type="file" class="form-control" accept="image/*" required />
            </div>

            <!-- PRODUCTS -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Select Products</label>

                <div class="picker-toolbar">
                    <input type="text" id="productSearch" class="form-control form-control-sm"
                           placeholder="Search products..." />
                    <button type="button" id="selectAllBtn" class="btn btn-sm btn-outline-secondary">All</button>
                    <button type="button" id="clearAllBtn" class="btn btn-sm btn-outline-secondary">None</button>
                </div>

                <div class="product-picker" id="productPicker">
                    @if (products == null || !products.Any())
                    {
                        <div class="p-3 text-muted small">No products available.</div>
                    }
                    else
                    {
                        @foreach (var p in products)
                        {
                            var firstImage = p.Images?.FirstOrDefault()?.ImageUrl;

                            <label class="product-row" data-name="@p.Name.ToLower()">
                                <input type="checkbox"
                                       name="ProductIds"
                                       value="@p.Id"
                                       class="form-check-input product-check" />

                                @if (!string.IsNullOrEmpty(firstImage))
                                {
                                    <img src="~/images/products/@firstImage"
                                         alt="@p.Name"
                                         class="product-thumb" />
                                }
                                else
                                {
                                    <div class="product-thumb-placeholder">N/A</div>
                                }

                                <div class="product-meta">
                                    <p class="product-name">@p.Name</p>
                                    <div class="product-sub">
                                        @p.CategoryName · @p.Price.ToString("N2") TL · Stock: @p.Stock
                                    </div>
                                </div>
                            </label>
                        }
                    }
                </div>

                <div class="picker-summary mt-2">
                    <span id="selectedCount">0</span> selected
                </div>
            </div>

            <!-- ACTIVE -->
            <div class="form-check mb-3">
                <input asp-for="IsActive" class="form-check-input" />
                <label class="form-check-label">Active</label>
            </div>

            <button class="btn btn-success">Create</button>

        </div>
    </form>
</div>

<script>
    (function () {
            const picker      = document.getElementById('productPicker');
            const search      = document.getElementById('productSearch');
            const selectAll   = document.getElementById('selectAllBtn');
            const clearAll    = document.getElementById('clearAllBtn');
            const summary     = document.getElementById('selectedCount');

            function rows() {
                return Array.from(picker.querySelectorAll('.product-row'));
            }

            function updateSummary() {
                const checked = picker.querySelectorAll('.product-check:checked').length;
                summary.textContent = checked;
            }

            function syncRowState(row) {
                const cb = row.querySelector('.product-check');
                row.classList.toggle('is-checked', cb.checked);
            }

            picker.addEventListener('change', function (e) {
                if (e.target.classList.contains('product-check')) {
                    syncRowState(e.target.closest('.product-row'));
                    updateSummary();
                }
            });

            search.addEventListener('input', function () {
                const term = this.value.trim().toLowerCase();
                rows().forEach(r => {
                    const match = !term || r.dataset.name.includes(term);
                    r.style.display = match ? '' : 'none';
                });
            });

            selectAll.addEventListener('click', function () {
                rows().forEach(r => {
                    if (r.style.display === 'none') return;
                    const cb = r.querySelector('.product-check');
                    cb.checked = true;
                    syncRowState(r);
                });
                updateSummary();
            });

            clearAll.addEventListener('click', function () {
                rows().forEach(r => {
                    const cb = r.querySelector('.product-check');
                    cb.checked = false;
                    syncRowState(r);
                });
                updateSummary();
            });

        // initial state
        rows().forEach(syncRowState);
        updateSummary();
    })();
</script>
