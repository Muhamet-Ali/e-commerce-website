@model GetSubCateogryByIdWithProductListDto

@{
    ViewData["Title"] = "Detail";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}


<div class="container-fluid px-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <h1>SubCategory Detail</h1>

        <a asp-area="Admin"
           asp-controller="SubCategory"
           asp-action="Index"
           class="btn btn-secondary">
            Back to List
        </a>
    </div>

    <!-- SubCategory Info -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <strong>Name:</strong> @Model.Name
                </div>
                <div class="col-md-4">
                    <strong>Category:</strong> @Model.CategoryName
                </div>
                <div class="col-md-4">
                    <strong>Product Count:</strong> @Model.ProductCount
                </div>
            </div>
        </div>
    </div>

    <!-- Products Table -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Products</h5>
        </div>
        <div class="card-body">

            <table class="table table-bordered table-hover">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Price</th>
                        <th>DiscountPrice</th>
                        <th>Stock</th>
                        <th>FavoriteCount</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Products != null && Model.Products.Any())
                    {
                        foreach (var item in Model.Products)
                        {
                            <tr>
                                <td>
                                    <img src="~/images/products/@item.Images.FirstOrDefault()?.ImageUrl" width="80" />
                                </td>
                                <td>@item.Name</td>
                                <td>@item.Price</td>
                                <td>@item.DiscountPrice</td>
                                <td>@item.Stock</td>
                                <td>@item.FavoriteCount</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                No Products found
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>
