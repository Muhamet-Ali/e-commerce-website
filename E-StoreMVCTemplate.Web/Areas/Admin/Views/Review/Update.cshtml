
@{
    ViewData["Title"] = "Update";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
@model UpdateReviewDto


<div class="container-fluid px-4 mt-4">

    <h2>Update Review</h2>

    <form asp-area="Admin"
          asp-controller="Review"
          asp-action="Update"
          method="post">

        <div class="card p-4">

            <input asp-for="Id" type="hidden" />

            <div class="mb-3">
                <label>Rating</label>
                <select asp-for="Rating" class="form-control" required>
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3</option>
                    <option value="4">4</option>
                    <option value="5">5</option>
                </select>
            </div>

            <div class="mb-3">
                <label>Comment</label>
                <textarea asp-for="Comment" class="form-control" rows="4"></textarea>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="IsApproved" class="form-check-input" />
                <label asp-for="IsApproved" class="form-check-label">Approved</label>
            </div>

            <button type="submit" class="btn btn-warning">Update</button>

        </div>
    </form>
</div>
