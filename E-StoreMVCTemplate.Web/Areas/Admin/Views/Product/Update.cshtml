@{
    ViewData["Title"] = "Update";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
@model UpdateProductDto

<div class="container-fluid px-4 mt-4">

    <h2>Update Product</h2>

    @if (Model.ExistingImages != null && Model.ExistingImages.Any())
    {
        <div class="mb-3">
            <label class="d-block">Current Images</label>
            <div class="d-flex flex-wrap gap-3">
                @foreach (var img in Model.ExistingImages.OrderBy(i => i.DisplayOrder))
                {
                    <form asp-area="Admin" asp-controller="Product" asp-action="DeleteImage" method="post" class="position-relative" style="width:160px;">
                        <input type="hidden" name="id" value="@img.Id" />
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <img src="~/images/products/@img.ImageUrl" style="width:160px; height:160px; object-fit:cover; border-radius:.4rem; border:1px solid #dee2e6;" />
                        <button type="submit"
                                class="btn btn-danger btn-sm position-absolute top-0 end-0 m-1 px-2 py-0"
                                title="Delete"
                                onclick="return confirm('Delete this image?');">
                            &times;
                        </button>
                    </form>
                }
            </div>
        </div>
    }

    <form asp-area="Admin"
          asp-controller="Product"
          asp-action="Update"
          method="post"
          enctype="multipart/form-data">

        <input type="hidden" asp-for="Id" />

        <div class="card p-4">

            <div class="mb-3">
                <label>Name</label>
                <input asp-for="Name" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>Description</label>
                <textarea asp-for="Description" class="form-control" rows="4" required></textarea>
            </div>

            <div class="mb-3">
                <label>Price</label>
                <input asp-for="Price" type="number" step="0.01" min="0" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>Stock</label>
                <input asp-for="Stock" type="number" min="0" class="form-control" required />
            </div>

            <div class="mb-3">
                <label>Category</label>
                <select id="categorySelect" asp-for="CategoryId" class="form-control" required>
                    <option value="">Select Category</option>

                    @foreach (var c in ViewBag.Categories)
                    {
                        <option value="@c.Id" selected="@(c.Id == Model.CategoryId)">@c.Name</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label>Sub Category</label>
                <select id="subCategorySelect" asp-for="SubCategoryId" class="form-control">
                    <option value="">Select Sub Category</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="d-block">Add New Images</label>
                <div id="fileInputs" class="d-flex flex-column gap-2">
                    <input name="Files" type="file" class="form-control" accept="image/*" />
                </div>
                <button type="button" id="addFileInputBtn" class="btn btn-outline-primary btn-sm mt-2">
                    + Add another image
                </button>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IsActive" class="form-check-input" />
                <label class="form-check-label">Active</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">Update</button>
                <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>

        </div>
    </form>
</div>


<script>
    var categories = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.Categories));
    var initialCategoryId = @Model.CategoryId;
    var initialSubCategoryId = @(Model.SubCategoryId?.ToString() ?? "null");

    function populateSubCategories(categoryId, selectedSubId) {
        var subSelect = document.getElementById("subCategorySelect");
        subSelect.innerHTML = '<option value="">Select Sub Category</option>';

        if (!categoryId) return;

        var cat = categories.find(c => c.Id == categoryId);
        if (cat && cat.subCategories) {
            cat.subCategories.forEach(function (sub) {
                var option = document.createElement("option");
                option.value = sub.Id;
                option.text = sub.Name;
                if (selectedSubId !== null && sub.Id == selectedSubId) {
                    option.selected = true;
                }
                subSelect.appendChild(option);
            });
        }
    }

    document.getElementById("categorySelect").addEventListener("change", function () {
        populateSubCategories(this.value, null);
    });

    populateSubCategories(initialCategoryId, initialSubCategoryId);

    document.getElementById("addFileInputBtn").addEventListener("click", function () {
        var input = document.createElement("input");
        input.type = "file";
        input.name = "Files";
        input.accept = "image/*";
        input.className = "form-control";
        document.getElementById("fileInputs").appendChild(input);
    });
</script>
