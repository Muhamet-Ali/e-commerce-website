@model List<GetHeadeImagesListDto>

@{
    ViewData["Title"] = "Header Images";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <h1>Header Images</h1>

        <form asp-area="Admin"
              asp-controller="HeaderImages"
              asp-action="Create"
              method="post"
              enctype="multipart/form-data"
              class="mb-4">

            <div class="card">
                <div class="card-body">

                    <div class="row g-3">

                        <!-- Image -->
                        <div class="col-md-4">
                            <label class="form-label">Select Image</label>
                            <input type="file" name="File" class="form-control" required />
                        </div>

                        <!-- Title (overlay text on image) -->
                        <div class="col-md-4">
                            <label class="form-label">Title (overlay text)</label>
                            <input type="text" name="Title" class="form-control" placeholder="Optional text shown on the image" />
                        </div>

                        <!-- Display Order -->
                        <div class="col-md-2">
                            <label class="form-label">Display Order</label>
                            <input type="number" name="DisplayOrder" class="form-control" value="1" />
                        </div>

                        <!-- Submit -->
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-success w-100">
                                Create
                            </button>
                        </div>

                    </div>

                </div>
            </div>
        </form>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            Header Images List
        </div>

        <div class="card-body">
            <table class="table table-bordered table-hover">
                <thead>
                    <tr>
                        <th>Image</th>
                        <th>Title</th>
                        <th>Display Order</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <img src="~/images/header/@item.ImageUrl"
                                         style="width:120px; height:70px; object-fit:cover;" />
                                </td>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(item.Title))
                                    {
                                        <span class="text-muted fst-italic">(no title)</span>
                                    }
                                    else
                                    {
                                        @item.Title
                                    }
                                </td>
                                <td>@item.DisplayOrder</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-area="Admin"
                                       asp-controller="HeaderImages"
                                       asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-danger"
                                       onclick="return confirm('Are you sure you want to delete it?')">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">
                                No images have been added yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>