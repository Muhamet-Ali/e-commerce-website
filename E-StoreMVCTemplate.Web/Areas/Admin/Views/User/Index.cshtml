
@{
    ViewData["Title"] = "Users";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@model List<GetUserListDto>


<div class="container-fluid px-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <h1>Users</h1>
    </div>

    <!-- Table -->
    <div class="card mb-4">
        <div class="card-body">

            <table class="table table-bordered table-hover">
                <thead>
                    <tr>
                        <th>UserName</th>
                        <th>Email</th>
                        <th>PhoneNumber</th>
                        <th>OrderCount</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @item.FullName
                                </td>
                                <td>
                                    @item.Email
                                </td>
                                <td>
                                    @item.PhoneNumber
                                </td>
                                <td>
                                    @item.OrderCount
                                </td>

                                <td class="text-end">

                                    <a asp-area="Admin"
                                       asp-controller="User"
                                       asp-action="Detail"
                                       asp-route-id="@item.Id"
                                       class="btn btn-info">
                                        Detail
                                    </a>
                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">
                                No Users found
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>
