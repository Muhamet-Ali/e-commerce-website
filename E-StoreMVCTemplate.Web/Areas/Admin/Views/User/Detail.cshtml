@using E_StoreMVCTemplate.Domain.Enums

@{
    ViewData["Title"] = "User Detail";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@model GetUserByIdDto


<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>User Detail</h1>
        <a asp-area="Admin"
           asp-controller="User"
           asp-action="Index"
           class="btn btn-secondary">
            Back to List
        </a>
    </div>

    <!-- User Info -->
    <div class="card mb-4">
        <div class="card-header">User Info</div>
        <div class="card-body">

            <table class="table table-bordered mb-0">
                <tr>
                    <th style="width: 200px;">UserName</th>
                    <td>@Model.FullName</td>
                </tr>
                <tr>
                    <th>Email</th>
                    <td>@Model.Email</td>
                </tr>
                <tr>
                    <th>PhoneNumber</th>
                    <td>@Model.PhoneNumber</td>
                </tr>
                <tr>
                    <th>Address</th>
                    <td>@Model.Address</td>
                </tr>
            </table>

        </div>
    </div>

    <!-- Orders -->
    <div class="card mb-4">
        <div class="card-header">Orders</div>
        <div class="card-body">

            <table class="table table-bordered table-hover">
                <thead>
                    <tr>
                        <th>OrderId</th>
                        <th>TotalAmount</th>
                        <th>Status</th>
                        <th>CreatedAt</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.UserOrders != null && Model.UserOrders.Any())
                    {
                        foreach (var order in Model.UserOrders)
                        {
                            <tr>
                                <td>@order.Id</td>
                                <td>@order.TotalAmount</td>
                                <td>
                                    @if (order.Status == OrderStatus.Pending)
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Confirmed</span>
                                    }
                                </td>
                                <td>@order.CreatedAt.ToShortDateString()</td>
                                <td class="text-end">
                                    <a asp-area="Admin"
                                       asp-controller="Order"
                                       asp-action="Detail"
                                       asp-route-id="@order.Id"
                                       class="btn btn-info">
                                        Detail
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">
                                No Orders found
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>
