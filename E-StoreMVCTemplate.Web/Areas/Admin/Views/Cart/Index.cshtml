
@{
    ViewData["Title"] = "Carts";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@model List<CartListDto>


<div class="container-fluid px-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <h1>Carts</h1>
    </div>

    <!-- Table -->
    <div class="card mb-4">
        <div class="card-body">

            <table class="table table-bordered table-hover">
                <thead>
                    <tr>
                        <th>CartId</th>
                        <th>UserName</th>
                        <th>Email</th>
                        <th>PhoneNumber</th>
                        <th>ItemCount</th>
                        <th>GrandTotal</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @item.Id
                                </td>
                                <td>
                                    @item.UserName
                                </td>
                                <td>
                                    @item.UserEmail
                                </td>
                                <td>
                                    @item.UserPhoneNumber
                                </td>
                                <td>
                                    @item.Items.Count
                                </td>
                                <td>
                                    @item.GrandTotal
                                </td>

                                <td class="text-end">

                                    <a asp-area="Admin"
                                       asp-controller="Cart"
                                       asp-action="Detail"
                                       asp-route-id="@item.Id"
                                       class="btn btn-info">
                                        Cart Detail
                                    </a>

                                    <a asp-area="Admin"
                                       asp-controller="User"
                                       asp-action="Detail"
                                       asp-route-id="@item.UserId"
                                       class="btn btn-secondary">
                                        User Detail
                                    </a>
                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">
                                No Carts found
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>
