
@{
    ViewData["Title"] = "Cart Detail";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

@model CartListDto


<div class="container-fluid px-4 mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Cart Detail</h1>
        <a asp-area="Admin"
           asp-controller="Cart"
           asp-action="Index"
           class="btn btn-secondary">
            Back to List
        </a>
    </div>

    <!-- User Info -->
    <div class="card mb-4">
        <div class="card-header">User Info</div>
        <div class="card-body">
            <table class="table table-bordered mb-0">
                <tr>
                    <th style="width: 200px;">CartId</th>
                    <td>@Model.Id</td>
                </tr>
                <tr>
                    <th>UserName</th>
                    <td>
                        <a asp-area="Admin"
                           asp-controller="User"
                           asp-action="Detail"
                           asp-route-id="@Model.UserId">
                            @Model.UserName
                        </a>
                    </td>
                </tr>
                <tr>
                    <th>Email</th>
                    <td>@Model.UserEmail</td>
                </tr>
                <tr>
                    <th>PhoneNumber</th>
                    <td>@Model.UserPhoneNumber</td>
                </tr>
            </table>
        </div>
    </div>

    <!-- Items -->
    <div class="card mb-4">
        <div class="card-header">Cart Items</div>
        <div class="card-body">

            <table class="table table-bordered table-hover">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Quantity</th>
                        <th>UnitPrice</th>
                        <th>SubTotal</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>@item.Quantity</td>
                                <td>@item.UnitPrice</td>
                                <td>@item.TotalPrice</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted">
                                No items in this cart
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="3" class="text-end">Grand Total</th>
                        <th>@Model.GrandTotal</th>
                    </tr>
                </tfoot>
            </table>

        </div>
    </div>

</div>
